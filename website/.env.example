# Marketing website (Stage 11) - public, build-time config. Copy to .env.local.
# Both are optional; sensible production defaults live in lib/site.ts.

# The marketing site's own origin - used for canonical URLs, Open Graph,
# sitemap, and robots. Set this to the deployed site origin in production.
NEXT_PUBLIC_SITE_URL=https://circlethedate.app

# The web app (the deployed Expo web build) - the "open the app" CTA target.
NEXT_PUBLIC_APP_URL=https://app.circlethedate.app
