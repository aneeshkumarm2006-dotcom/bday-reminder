# Marketing website (Stage 11) - public, build-time config. Copy to .env.local.
# Both are optional; sensible production defaults live in lib/site.ts.

# The marketing site's own origin - used for canonical URLs, Open Graph,
# sitemap, and robots. Set this to the deployed site origin in production.
NEXT_PUBLIC_SITE_URL=https://circlethedate.app

# The web app (the deployed Expo web build) - the "open the app" CTA target.
NEXT_PUBLIC_APP_URL=https://app.circlethedate.app

# The backend API base URL the in-site web app talks to (auth, people,
# reminders, …). Defaults to http://localhost:4040 in dev (see lib/api.ts).
# Set this to the deployed API origin in production.
NEXT_PUBLIC_API_URL=http://localhost:4040


# ──────────────────────────────────────────────────────────────────────────
# SEO blog dashboard (/seoteam) — server-only secrets. Required for the blog.
# ──────────────────────────────────────────────────────────────────────────

# Shared password the SEO team uses to sign into /seoteam. Pick a strong one.
SEO_DASHBOARD_PASSWORD=change-me

# Secret used to sign the dashboard session cookie. MUST be at least 32 chars.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-32-plus-character-secret

# MongoDB connection string for storing blog posts. Reuse the same cluster as
# the backend (the website connects directly, with its own pooled connection).
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/circlethedate

# Cloudinary (cover + inline editor image uploads). All optional — when unset
# the editor falls back to inlining images as data URIs so dev still works.
# You can reuse the backend's Cloudinary account/credentials.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Folder uploaded images are placed in (defaults to "circlethedate-blog").
CLOUDINARY_UPLOAD_FOLDER=circlethedate-blog
