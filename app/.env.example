# =============================================================================
# Birthday Reminder - app (Expo) environment variables
# Copy to `.env` and fill in. NEVER commit the real `.env`.
#
# Expo only exposes variables prefixed with EXPO_PUBLIC_ to client code.
# These are bundled into the app and are NOT secret - keep real secrets in the
# backend. The [Stage N] tag marks when each key first becomes used.
# =============================================================================

# --- Backend API base URL [Stage 2] ------------------------------------------
# Web / simulator can use localhost. On a physical device, use your machine's
# LAN IP instead (e.g. http://192.168.1.20:4040) so the phone can reach the API.
EXPO_PUBLIC_API_URL=http://localhost:4040
