{
  "name": "birthday-reminder-e2e",
  "version": "0.1.0",
  "private": true,
  "description": "End-to-end web tests (Playwright) for the Birthday Reminder app, driven against an in-memory backend (TODO Stage 13).",
  "scripts": {
    "build:app": "npm --prefix ../app run build",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ci": "npm run build:app && playwright test",
    "install:browsers": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0"
  }
}
