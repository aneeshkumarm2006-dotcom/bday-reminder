# =============================================================================
# Birthday Reminder — backend environment variables
# Copy to `.env` and fill in. NEVER commit the real `.env`.
# The [Stage N] tag marks when each key first becomes required.
# =============================================================================

# --- Core server [Stage 0] ---------------------------------------------------
NODE_ENV=development
# 4040 by default (4000 is a common conflict on dev machines).
PORT=4040

# Comma-separated origins allowed by CORS (the app + the website). [Stage 1]
# APP_ORIGIN doubles as the base for shared-list invite accept links
# (`<APP_ORIGIN>/invite/<token>`) emailed in Stage 8. [Stage 8]
APP_ORIGIN=http://localhost:8081
WEBSITE_ORIGIN=http://localhost:3000

# The backend's own public base URL — used to build the calendar subscribe link
# (`<API_PUBLIC_URL>/calendar/<token>.ics`) shown in the app. [Stage 9]
# In production set this to the deployed API origin (e.g. https://api.yourdomain.com).
API_PUBLIC_URL=http://localhost:4040

# --- Database [Stage 1] ------------------------------------------------------
# MongoDB Atlas connection string (free M0 cluster).
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/birthday-reminder?retryWrites=true&w=majority

# Optional: comma-separated DNS server IPs (e.g. 1.1.1.1,8.8.8.8). Only needed if
# Node's DNS resolver fails the SRV lookup behind mongodb+srv:// with
# `querySrv ECONNREFUSED` (a Windows/c-ares quirk). Leave unset in prod/CI.
# DNS_SERVERS=1.1.1.1,8.8.8.8

# --- Auth / JWT [Stage 1] ----------------------------------------------------
# Use long, random strings (e.g. `openssl rand -base64 48`). Keep these distinct.
# Minimum 32 characters each (HS256 wants >=256 bits of entropy). [Stage 12]
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# --- Email delivery — Resend [Stage 4] ---------------------------------------
# Also used to email shared-list invites in Stage 8. Without a key, invites are
# still created (the owner shares the returned accept link) — the email is just
# logged and skipped.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# Must be a verified sender/domain in Resend.
EMAIL_FROM="Birthday Reminder <reminders@yourdomain.com>"

# --- Push notifications — Expo [Stage 4] -------------------------------------
# Optional: only needed for the Expo push receipts/security feature.
EXPO_ACCESS_TOKEN=

# --- Reminder scheduler — node-cron [Stage 4] --------------------------------
# How often the in-process dispatcher fires due reminders. Default every 15 min.
REMINDER_DISPATCH_CRON=*/15 * * * *
# Set to false to skip starting the in-process scheduler (e.g. when a host
# scheduler / separate worker drives dispatch instead). Default true.
REMINDER_JOBS_ENABLED=true

# --- Photo hosting — Cloudinary [Stage 6] ------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SMS / WhatsApp — Twilio [DEFERRED until SMS go-live] --------------------
# Delivery is stubbed behind a provider interface for now (Stage 5).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# Fair-use cap: max SMS/WhatsApp reminders per user per month. [Stage 5]
# Business-configurable — read from config, never hardcoded into UI copy (FR-55/56).
SMS_WHATSAPP_MONTHLY_CAP=20

# --- Rate limiting [Stage 12] ------------------------------------------------
# On by default outside tests. A strict per-IP limiter guards the credential
# endpoints (login/signup, independent counters) and a lenient one caps overall
# flooding. Set RATE_LIMIT_ENABLED=false to disable, or =true to force-enable in
# a test. Behind a proxy (Render/Railway) the app trusts one X-Forwarded-For hop.
# RATE_LIMIT_ENABLED=true
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
GLOBAL_RATE_LIMIT_MAX=300
GLOBAL_RATE_LIMIT_WINDOW_MS=60000
# Trusted proxy hops in front of the app (Express `trust proxy`) so req.ip is the
# real client for rate-limit keying. MUST match the deploy topology: 0 = direct,
# 1 = one proxy (Render/Railway/Fly). Defaults to 1 in production, 0 elsewhere.
# TRUST_PROXY_HOPS=1
